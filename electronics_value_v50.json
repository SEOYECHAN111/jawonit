<!doctype html>
<html lang="ko">
<head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, max-age=0"><meta http-equiv="Pragma" content="no-cache"><meta http-equiv="Expires" content="0"><title>문서함 | 자원잇다</title><link rel="icon" href="/assets/favicon.png?v=51.12.0"><link rel="stylesheet" href="/css/styles.css?v=51.12.0"></head>
<body>
<header class="site-header"><div class="container nav"><a class="brand brand-image" href="/index.html"><img src="/assets/jawonitda-logo.png?v=51.12.0" alt="자원잇다"></a><button class="mobile-toggle" id="mobileToggle">메뉴</button><nav class="menu" id="menu"></nav><div class="nav-spacer"></div><div class="account-area" id="accountArea"></div></div></header>
<main class="section"><div class="container"><section class="policy-hero"><span class="eyebrow">Document Archive</span><h1>발급 문서함</h1><p>발급된 견적서, 인보이스, 정산서, 확인서의 PDF/HTML 이력을 확인합니다.</p><div class="row-actions" style="margin-top:18px"><a class="btn primary" href="/document-center.html">새 문서 발급</a><a class="btn ghost" href="/dashboards/admin.html#template-admin">서류양식 관리</a></div></section><section class="card"><h2>최근 발급 문서</h2><div id="docs">불러오는 중...</div></section></div></main><div class="quick-help" id="quickHelp"></div><footer class="footer"><div class="container footer-grid"><div><b>자원잇다</b><p>발급 문서함</p></div><div><b>문서</b><p><a href="/document-center.html">문서발급</a></p><p><a href="/dashboards/admin.html#template-admin">양식관리</a></p></div><div><b>고객센터</b><p>1544-0000</p></div></div></footer><script src="/js/app.js?v=51.12.0"></script><script>
async function load(){const r=await fetch('/api/v49/documents?limit=100'); const j=await r.json(); const rows=j.documents||[]; document.getElementById('docs').innerHTML=rows.length?`<div class="table-wrap"><table class="table"><thead><tr><th>문서번호</th><th>템플릿</th><th>수신자</th><th>합계</th><th>발급일</th><th>열기</th></tr></thead><tbody>${rows.map(d=>`<tr><td>${d.doc_no}</td><td>${d.template_id}</td><td>${d.recipient?.name||''}</td><td>${(d.totals?.total_amount||0).toLocaleString()}원</td><td>${d.issued_at}</td><td><a target="_blank" href="/api/v49/documents/${d.id}/pdf">PDF</a> · <a target="_blank" href="/api/v49/documents/${d.id}/html">HTML</a></td></tr>`).join('')}</tbody></table></div>`:'아직 발급된 문서가 없습니다.';} load();
</script></body></html>